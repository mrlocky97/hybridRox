{
  "name": "hybridrox",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/pocketbase\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:pb": "npm run dev --prefix apps/pocketbase",
    "build": "npm run build --prefix apps/web",
    "start:pb": "npm run start --prefix apps/pocketbase",
    "lint": "npm run lint --prefix apps/web"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "workspaces": [
    "apps/*"
  ]
}